<?xml version="1.0"?>
<!--
  Mobile base macro (kinematic режим VelocityControl + OdometryPublisher).
  =========================================================================
  В этой версии:
    * НЕТ MecanumDrive, НЕТ ros2_control блока для колёс.
    * gz_sim::systems::VelocityControl слушает /cmd_vel (GZ-топик) и НАПРЯМУЮ
      задаёт линейную и угловую скорость base_link. Это кинематический режим:
      робот идеально следует cmd_vel, без проскальзываний.
    * gz_sim::systems::OdometryPublisher публикует /odom (GZ-топик) по реальной
      позе base_link относительно odom-фрейма + TF одометрии.
    * 4 колеса оставлены ВИЗУАЛЬНО как раньше, но их collision отключён
      и они подвешены через fixed-джойнты - не влияют на физику.
    * 3 кастера-шарика с почти нулевым трением держат корпус над полом
      (без них VelocityControl может конфликтовать с гравитацией на старте).

  Макрос xacro:mobile_base принимает те же параметры, что и раньше.
  Старый макрос mecanum_drive_plugin удалён, добавлен velocity_control_plugin.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ====== Параметры по умолчанию ====== -->
  <xacro:property name="default_base_l"        value="1.00"/>
  <xacro:property name="default_base_w"        value="0.45"/>
  <xacro:property name="default_base_h"        value="0.545"/>
  <xacro:property name="default_base_mass"     value="30.0"/>
  <xacro:property name="default_wheel_radius"  value="0.10"/>
  <xacro:property name="default_wheel_thick"   value="0.050"/>
  <xacro:property name="default_wheel_mass"    value="1.0"/>
  <xacro:property name="default_wheel_x"       value="${default_base_l / 2.0 - default_wheel_radius}"/>
  <xacro:property name="default_wheel_y"       value="${default_base_w / 2.0}"/>
  <xacro:property name="default_mount_height"  value="0.14"/>
  <xacro:property name="default_mount_lingth"  value="0.2"/>
  <xacro:property name="default_mount_x"       value="${(default_base_l - default_mount_lingth) / 2.0}"/>
  

  <!-- ====== Локальный макрос: кастер-шарик с нулевым трением ====== -->
  
  <xacro:macro name="caster_ball" params="prefix name xyz mass radius">
    <xacro:property name="ball_inertia" value="${ (2/5) * mass * radius * radius }"/>
    <link name="${prefix}caster_${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${radius}"/>
          <!-- <cylinder radius="${radius}"/> -->
        </geometry>
        <material name="${prefix}wheel_mat">
          <color rgba="0.10 0.10 0.10 1.0"/>
        </material>
      </visual>

      <collision>
        <geometry>
          <sphere radius="${radius}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.00001</mu>
              <mu2>0.00001</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <!-- <visual>
        <geometry>
          <sphere radius="0.005"/>
        </geometry>
      </visual> -->
      <inertial>
        <mass value="${mass}"/>
        <inertia ixx="${ball_inertia}" iyy="${ball_inertia}" izz="${ball_inertia}" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${prefix}caster_${name}_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}caster_${name}"/>
      <origin xyz="${xyz}"/>
    </joint>
    <gazebo reference="${prefix}caster_${name}">
      <visual>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <mu1>0.00001</mu1>
      <mu2>0.00001</mu2>
    </gazebo>
  </xacro:macro>

  <!-- ====== ОСНОВНОЙ МАКРОС ПЛАТФОРМЫ ====== -->
  <xacro:macro name="mobile_base"
               params="prefix:=''
                       base_l:=${default_base_l}
                       base_w:=${default_base_w}
                       base_h:=${default_base_h}
                       base_mass:=${default_base_mass}
                       wheel_radius:=${default_wheel_radius}
                       wheel_thick:=${default_wheel_thick}
                       wheel_mass:=${default_wheel_mass}
                       wheel_x:=${default_wheel_x}
                       wheel_y:=${default_wheel_y}
                       mount_height:=${default_mount_height}">

    <!-- ================== base_footprint (на полу) ================== -->
    <link name="${prefix}base_footprint"/>

    <joint name="${prefix}base_footprint_joint" type="fixed">
      <parent link="${prefix}base_footprint"/>
      <child  link="${prefix}base_link"/>
      <origin xyz="0 0 ${wheel_radius + base_h/2.0}" rpy="0 0 0"/>
    </joint>

    <!-- ================== base_link (корпус) ================== -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${base_l} ${base_w} ${base_h}"/>
        </geometry>
        <material name="${prefix}base_mat">
          <color rgba="0.20 0.40 0.65 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${base_l} ${base_w} ${base_h}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${base_mass}"/>
        <inertia
          ixx="${base_mass*(base_w*base_w + base_h*base_h)/12.0}"
          iyy="${base_mass*(base_l*base_l + base_h*base_h)/12.0}"
          izz="${base_mass*(base_l*base_l + base_w*base_w)/12.0}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <gazebo reference="${prefix}base_link">
      <!-- Низкое трение корпуса по самому себе - на случай, если уголок
           коснётся земли при наклоне. -->
      <mu1>0.1</mu1>
      <mu2>0.1</mu2>
      <visual>
        <material>
          <diffuse>0.20 0.40 0.65 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>
    </gazebo>

    <!-- ================== z1_mount: площадка под Z1 ================== -->
    <link name="${prefix}z1_mount">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.20 0.20 ${mount_height}"/>
        </geometry>
        <material name="${prefix}mount_mat">
          <color rgba="0.30 0.30 0.30 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.20 0.20 ${mount_height}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}z1_mount_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}z1_mount"/>
      <origin xyz="${default_mount_x} 0 ${base_h/2.0 + mount_height/2.0}" rpy="0 0 0"/>
    </joint>

    <!-- ================== 4 ВИЗУАЛЬНЫХ колеса ================== -->
    <xacro:property name="wheel_z_local" value="${-base_h/2.0}"/>

    <!-- <xacro:dummy_wheel prefix="${prefix}" name="fl"
                       xyz="${ wheel_x}  ${ wheel_y} ${wheel_z_local}"
                       mass="${wheel_mass}" radius="${wheel_radius}" thick="${wheel_thick}"/>
    <xacro:dummy_wheel prefix="${prefix}" name="fr"
                       xyz="${ wheel_x} ${-wheel_y} ${wheel_z_local}"
                       mass="${wheel_mass}" radius="${wheel_radius}" thick="${wheel_thick}"/>
    <xacro:dummy_wheel prefix="${prefix}" name="rl"
                       xyz="${-wheel_x}  ${ wheel_y} ${wheel_z_local}"
                       mass="${wheel_mass}" radius="${wheel_radius}" thick="${wheel_thick}"/>
    <xacro:dummy_wheel prefix="${prefix}" name="rr"
                       xyz="${-wheel_x} ${-wheel_y} ${wheel_z_local}"
                       mass="${wheel_mass}" radius="${wheel_radius}" thick="${wheel_thick}"/> -->

    <!-- ================== 3 кастера-шарика ================== -->
    <!-- Низ корпуса лежит на z = -base_h/2. Кастеры висят чуть ниже,
         чтобы они касались земли, а корпус - нет.
         z_caster_local = -base_h/2 - wheel_radius + 0.005
         (сфера радиуса 0.005 должна касаться z=0 при footprint=z=0). -->
    <!-- <xacro:property name="caster_z" value="${-base_h/2.0 - wheel_radius + 0.005}"/> -->


    <xacro:caster_ball prefix="${prefix}" name="fl"
                       xyz="${ wheel_x}  ${ wheel_y} ${-base_h / 2.0}"
                       mass="${wheel_mass}" radius="${wheel_radius}"/>
    <xacro:caster_ball prefix="${prefix}" name="fr"
                       xyz="${ wheel_x} ${-wheel_y} ${-base_h / 2.0}"
                       mass="${wheel_mass}" radius="${wheel_radius}"/>

    <xacro:caster_ball prefix="${prefix}" name="rl"
                       xyz="${-wheel_x}  ${ wheel_y} ${-base_h / 2.0}"
                       mass="${wheel_mass}" radius="${wheel_radius}"/>
    <xacro:caster_ball prefix="${prefix}" name="rr"
                       xyz="${-wheel_x} ${-wheel_y} ${-base_h / 2.0}"
                       mass="${wheel_mass}" radius="${wheel_radius}"/>

  </xacro:macro>

  <!-- ============================================================
       ВСТРОЕННЫЕ ПЛАГИНЫ: VelocityControl + OdometryPublisher.
       Параметры:
         topic              - GZ-топик для cmd_vel (default: cmd_vel).
                              Через ros_gz_bridge доступен из ROS2.
         odom_topic         - GZ-топик одометрии (default: odom).
         tf_topic           - GZ-топик TF (default: tf).
         frame_id           - имя odom-фрейма.
         child_frame_id     - имя base-фрейма для одометрии.
       ============================================================ -->
  <xacro:macro name="velocity_control_plugin"
               params="prefix:=''
                       topic:='cmd_vel'
                       odom_topic:='odom'
                       tf_topic:='tf'
                       frame_id:='odom'
                       child_frame_id:='base_footprint'
                       odom_pub_frequency:='50'">
    <gazebo>
      <!-- 1. VelocityControl: cmd_vel напрямую в скорость base_link -->
      <plugin filename="gz-sim-velocity-control-system"
              name="gz::sim::systems::VelocityControl">
        <topic>${topic}</topic>
      </plugin>

      <!-- 2. OdometryPublisher: реальная поза base_link -> /odom + TF -->
      <plugin filename="gz-sim-odometry-publisher-system"
              name="gz::sim::systems::OdometryPublisher">
        <odom_frame>${frame_id}</odom_frame>
        <robot_base_frame>${prefix}base_link</robot_base_frame>
        <odom_publish_frequency>${odom_pub_frequency}</odom_publish_frequency>
        <odom_topic>${odom_topic}</odom_topic>
        <tf_topic>${tf_topic}</tf_topic>
        <dimensions>3</dimensions>
      </plugin>
    </gazebo>
  </xacro:macro>

</robot>
