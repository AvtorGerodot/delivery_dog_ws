<?xml version="1.0"?>
<!--
  Макрос-версия URDF манипулятора Z1 (без link "world").
  Используется, когда Z1 нужно прикрепить к другому роботу (мобильная база, B2).

  Внутри определены ТОЛЬКО:
    * макрос xacro:z1_arm     - линки/джойнты руки + захвата (без link world,
                                без gazebo-плагина gz_ros2_control и без ros2_control блока).
    * макрос xacro:z1_ros2_control - блок ros2_control с effort-интерфейсами
                                на 7 джойнтов (с учётом prefix).

  Подключение из родительского xacro:

      <xacro:include filename="$(find z1_model)/urdf/z1_arm_macro.urdf.xacro"/>
      <xacro:z1_arm prefix="z1_" parent="z1_mount" xyz="0 0 0" rpy="0 0 0"
                    use_gripper="true"/>
      <xacro:z1_ros2_control prefix="z1_"/>

  Сам gz_ros2_control-plugin подключать НЕ ЗДЕСЬ, а в финальном composite-URDF
  (delivery_dog_bringup/urdf/mobile_z1.urdf.xacro) - один плагин на всю модель.

  Все имена линков/джойнтов получают префикс ${prefix}, чтобы две копии
  Z1 (или Z1 рядом с другими манипуляторами) не конфликтовали по именам.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Параметры и материалы Z1 -->
  <xacro:include filename="const.xacro"/>
  <xacro:include filename="materials.xacro"/>
  <xacro:include filename="transmission.xacro"/>

  <!-- ======================================================================
       МАКРОС МАНИПУЛЯТОРА Z1
       Параметры:
         prefix       - префикс к именам линков/джойнтов (например "z1_").
                        Если ставится один Z1, можно оставить prefix="".
         parent       - имя parent-link, к которому крепится база Z1 (link00).
         xyz / rpy    - origin крепления link00 относительно parent.
         use_gripper  - "true" / "false" - подключать ли захват Unitree.
       ====================================================================== -->
  <xacro:macro name="z1_arm"
               params="prefix:='' parent:='world' xyz:='0 0 0' rpy:='0 0 0'
                       use_gripper:=true">

    <!-- Жёсткое крепление link00 к parent (заменяет старый base_static_joint от world). -->
    <joint name="${prefix}base_static_joint" type="fixed">
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <parent link="${parent}"/>
      <child  link="${prefix}link00"/>
    </joint>

    <link name="${prefix}link00">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link00.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_gold"/>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${motor_height}" radius="${motor_diameter}"/>
        </geometry>
        <origin rpy="0 0 0" xyz="0 0 ${motor_height/2.0}"/>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${L00_ComX} ${L00_ComY} ${L00_ComZ}"/>
        <mass value="${L00_Mass}"/>
        <inertia ixx="${L00_Ixx}" ixy="${L00_Ixy}" ixz="${L00_Ixz}"
                 iyy="${L00_Iyy}" iyz="${L00_Iyz}" izz="${L00_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint1" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0.0585"/>
      <parent link="${prefix}link00"/>
      <child  link="${prefix}link01"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
      <limit effort="${torqueMax}" velocity="${velocityMax}"
             lower="${joint1_PositionMin}" upper="${joint1_PositionMax}"/>
    </joint>

    <link name="${prefix}link01">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link01.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_gold"/>
      </visual>
      <inertial>
        <origin rpy="0 0 0" xyz="${L01_ComX} ${L01_ComY} ${L01_ComZ}"/>
        <mass value="${L01_Mass}"/>
        <inertia ixx="${L01_Ixx}" ixy="${L01_Ixy}" ixz="${L01_Ixz}"
                 iyy="${L01_Iyy}" iyz="${L01_Iyz}" izz="${L01_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint2" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0.045"/>
      <parent link="${prefix}link01"/>
      <child  link="${prefix}link02"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${2*jointDamping}" friction="${2*jointFriction}"/>
      <limit effort="${2*torqueMax}" velocity="${velocityMax}"
             lower="${joint2_PositionMin}" upper="${joint2_PositionMax}"/>
    </joint>

    <link name="${prefix}link02">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link02.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_red"/>
      </visual>
      <collision>
        <geometry><cylinder length="${2.0*motor_height}" radius="${motor_diameter}"/></geometry>
        <origin rpy="${PI/2.0} 0 0" xyz="0 0 0"/>
      </collision>
      <collision>
        <geometry><cylinder length="${arm1_height}" radius="${arm1_diameter}"/></geometry>
        <origin rpy="0 ${PI/2.0} 0" xyz="${-0.045-arm1_height/2.0} 0 0"/>
      </collision>
      <collision>
        <geometry><cylinder length="${motor_height}" radius="${motor_diameter}"/></geometry>
        <origin rpy="${PI/2.0} 0 0" xyz="-0.35 0 0"/>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${L02_ComX} ${L02_ComY} ${L02_ComZ}"/>
        <mass value="${L02_Mass}"/>
        <inertia ixx="${L02_Ixx}" ixy="${L02_Ixy}" ixz="${L02_Ixz}"
                 iyy="${L02_Iyy}" iyz="${L02_Iyz}" izz="${L02_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint3" type="revolute">
      <origin rpy="0 0 0" xyz="-0.35 0 0"/>
      <parent link="${prefix}link02"/>
      <child  link="${prefix}link03"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
      <limit effort="${torqueMax}" velocity="${velocityMax}"
             lower="${joint3_PositionMin}" upper="${joint3_PositionMax}"/>
    </joint>

    <link name="${prefix}link03">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link03.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_red"/>
      </visual>
      <collision>
        <geometry><cylinder length="${arm2_height-0.01}" radius="${arm2_diameter}"/></geometry>
        <origin rpy="0 ${PI/2.0} 0" xyz="${0.065+arm2_height/2.0} 0 0.055"/>
      </collision>
      <collision>
        <geometry><cylinder length="0.059" radius="${motor_diameter}"/></geometry>
        <origin rpy="0 ${PI/2.0} ${PI/2.0}" xyz="${0.065+0.185-0.059/2.0} 0 0.055"/>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${L03_ComX} ${L03_ComY} ${L03_ComZ}"/>
        <mass value="${L03_Mass}"/>
        <inertia ixx="${L03_Ixx}" ixy="${L03_Ixy}" ixz="${L03_Ixz}"
                 iyy="${L03_Iyy}" iyz="${L03_Iyz}" izz="${L03_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint4" type="revolute">
      <origin rpy="0 0 0" xyz="0.218 0 0.057"/>
      <parent link="${prefix}link03"/>
      <child  link="${prefix}link04"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
      <limit effort="${torqueMax}" velocity="${velocityMax}"
             lower="${joint4_PositionMin}" upper="${joint4_PositionMax}"/>
    </joint>

    <link name="${prefix}link04">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link04.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_gold"/>
      </visual>
      <collision>
        <geometry><cylinder length="${motor_height + 2*0.008}" radius="${motor_diameter}"/></geometry>
        <origin rpy="0 0 0" xyz="0.072 0 0"/>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${L04_ComX} ${L04_ComY} ${L04_ComZ}"/>
        <mass value="${L04_Mass}"/>
        <inertia ixx="${L04_Ixx}" ixy="${L04_Ixy}" ixz="${L04_Ixz}"
                 iyy="${L04_Iyy}" iyz="${L04_Iyz}" izz="${L04_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint5" type="revolute">
      <origin rpy="0 0 0" xyz="0.07 0.0 0.0"/>
      <parent link="${prefix}link04"/>
      <child  link="${prefix}link05"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
      <limit effort="${torqueMax}" velocity="${velocityMax}"
             lower="${joint5_PositionMin}" upper="${joint5_PositionMax}"/>
    </joint>

    <link name="${prefix}link05">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link05.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_red"/>
      </visual>
      <inertial>
        <origin rpy="0 0 0" xyz="${L05_ComX} ${L05_ComY} ${L05_ComZ}"/>
        <mass value="${L05_Mass}"/>
        <inertia ixx="${L05_Ixx}" ixy="${L05_Ixy}" ixz="${L05_Ixz}"
                 iyy="${L05_Iyy}" iyz="${L05_Iyz}" izz="${L05_Izz}"/>
      </inertial>
    </link>

    <joint name="${prefix}joint6" type="revolute">
      <origin rpy="0 0 0" xyz="0.0492 0.0 0.0"/>
      <parent link="${prefix}link05"/>
      <child  link="${prefix}link06"/>
      <axis xyz="1 0 0"/>
      <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
      <limit effort="${torqueMax}" velocity="${velocityMax}"
             lower="${joint6_PositionMin}" upper="${joint6_PositionMax}"/>
    </joint>

    <link name="${prefix}link06">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="$(find z1_model)/meshes/visual/z1_Link06.dae" scale="1 1 1"/>
        </geometry>
        <material name="iron_gold"/>
      </visual>
      <collision>
        <geometry><cylinder length="${motor_height}" radius="${motor_diameter}"/></geometry>
        <origin rpy="0 ${PI/2.0} 0" xyz="${motor_height/2.0} 0 0"/>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${L06_ComX} ${L06_ComY} ${L06_ComZ}"/>
        <mass value="${L06_Mass}"/>
        <inertia ixx="${L06_Ixx}" ixy="${L06_Ixy}" ixz="${L06_Ixz}"
                 iyy="${L06_Iyy}" iyz="${L06_Iyz}" izz="${L06_Izz}"/>
      </inertial>
    </link>

    <!-- Захват Unitree (опционально) -->
    <xacro:if value="${use_gripper}">
      <joint name="${prefix}gripperStator_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.051 0.0 0.0"/>
        <parent link="${prefix}link06"/>
        <child  link="${prefix}gripperStator"/>
      </joint>

      <link name="${prefix}gripperStator">
        <visual>
          <geometry>
            <mesh filename="$(find z1_model)/meshes/visual/stl_models/z1_GripperStator.stl" scale="1 1 1"/>
          </geometry>
          <material name="iron_red"/>
        </visual>
        <collision>
          <geometry>
            <mesh filename="$(find z1_model)/meshes/collision/z1_GripperStator.STL" scale="1 1 1"/>
          </geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${GripperStator_ComX} ${GripperStator_ComY} ${GripperStator_ComZ}"/>
          <mass value="${GripperStator_Mass}"/>
          <inertia ixx="${GripperStator_Ixx}" ixy="${GripperStator_Ixy}" ixz="${GripperStator_Ixz}"
                   iyy="${GripperStator_Iyy}" iyz="${GripperStator_Iyz}" izz="${GripperStator_Izz}"/>
        </inertial>
      </link>

      <joint name="${prefix}jointGripper" type="revolute">
        <origin rpy="0 0 0" xyz="0.049 0.0 0"/>
        <parent link="${prefix}gripperStator"/>
        <child  link="${prefix}gripperMover"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="${jointDamping}" friction="${jointFriction}"/>
        <limit effort="${torqueMax}" velocity="${velocityMax}"
               lower="${Gripper_PositionMin}" upper="${Gripper_PositionMax}"/>
      </joint>

      <link name="${prefix}gripperMover">
        <visual>
          <geometry>
            <mesh filename="$(find z1_model)/meshes/visual/stl_models/z1_GripperMover.stl" scale="1 1 1"/>
          </geometry>
          <material name="iron_gold"/>
        </visual>
        <collision>
          <geometry>
            <mesh filename="$(find z1_model)/meshes/collision/z1_GripperMover.STL" scale="1 1 1"/>
          </geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${GripperMover_ComX} ${GripperMover_ComY} ${GripperMover_ComZ}"/>
          <mass value="${GripperMover_Mass}"/>
          <inertia ixx="${GripperMover_Ixx}" ixy="${GripperMover_Ixy}" ixz="${GripperMover_Ixz}"
                   iyy="${GripperMover_Iyy}" iyz="${GripperMover_Iyz}" izz="${GripperMover_Izz}"/>
        </inertial>
      </link>

      <xacro:motorTransmission name="${prefix}Gripper"/>
    </xacro:if>

    <xacro:motorTransmission name="${prefix}1"/>
    <xacro:motorTransmission name="${prefix}2"/>
    <xacro:motorTransmission name="${prefix}3"/>
    <xacro:motorTransmission name="${prefix}4"/>
    <xacro:motorTransmission name="${prefix}5"/>
    <xacro:motorTransmission name="${prefix}6"/>
  </xacro:macro>

  <!-- ======================================================================
       МАКРОС ros2_control блока для Z1.
       ВНИМАНИЕ: сам plugin gz_ros2_control НЕ подключаем здесь -
       это делается один раз в composite-URDF, иначе в Gazebo поднимутся
       два независимых controller_manager и /joint_states будет ломаться.
       ====================================================================== -->
  <xacro:macro name="z1_ros2_control"
               params="prefix:='' use_gripper:=true name:=Z1GazeboSystem">
    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <xacro:joint_controller name="${prefix}joint1" initial_position="0.0"/>
      <xacro:joint_controller name="${prefix}joint2" initial_position="0.0"/>
      <xacro:joint_controller name="${prefix}joint3" initial_position="-0.035"/>
      <xacro:joint_controller name="${prefix}joint4" initial_position="-1.047"/>
      <xacro:joint_controller name="${prefix}joint5" initial_position="0.0"/>
      <xacro:joint_controller name="${prefix}joint6" initial_position="0.0"/>

      <xacro:if value="${use_gripper}">
        <xacro:joint_controller name="${prefix}jointGripper" initial_position="0.0"/>
      </xacro:if>
    </ros2_control>
  </xacro:macro>

  <!-- Локальный макрос-обёртка для регистрации одного джойнта в ros2_control.
       Effort-интерфейс в командах + position/velocity/effort в стейте. -->
  <xacro:macro name="joint_controller" params="name initial_position">
    <joint name="${name}">
      <command_interface name="effort">
        <param name="min">-33</param>
        <param name="max">33</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">${initial_position}</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>

</robot>
